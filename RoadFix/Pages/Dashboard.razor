@page "/dashboard"
@using Postgrest.Attributes
@using Postgrest
@using RoadFix.Services
@using Postgrest.Models
@inject IJSRuntime JSRuntime
@inject Supabase.Client Supabase
@inject NavigationManager Navigation
<PageTitle>Dashboard - RoadFix</PageTitle>

<HeadContent>
    <style>
        .dashboard-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 2rem;
        }

        .dashboard-content {
            background-color: rgba(255, 255, 255, 0.9);
            border-radius: 10px;
        }
    </style>
<div class="dashboard-content" width= "90%" height = "50%" justify-content= "center" align-items= "center" padding= "1rem">
        <h1>Welcome to Your Dashboard</h1>
        
    </div>
</HeadContent>

<div class="dashboard-container" width= "90%" justify-content= "center" align-items= "center" padding= "1rem">
    


    <div class="hero-bg">
        <div class="fade-in-box">
           <a href= "/Historicservice" class="main-wrapper">
            <h1>Service History</h1>
            
        </a>
    </div>
    </div>

    <div class = "hero-bg">
         <div class="fade-in-box">
           <a href= "/services" class="main-wrapper">
            <h1>Order Services</h1>
            
        </a>
    </div>
    </div>

    <div class = "hero-bg">
         <div class="fade-in-box">
           <a href= "/profile" class="main-wrapper">
            <h1>Profile</h1>
            
        </a>
    </div>
    
    </div>
    <div>
        <section id="contact" class="text-center">
        <h2 class="mb-4">Contact Us Today</h2>
        <p class="mb-4">Ready to fix those potholes? Get in touch for a free assessment and quote.</p>
        <div class="row">
            <div class="col-md-4">
                <i class="bi bi-telephone display-6 text-primary mb-2"></i>
                <h5>Call Us</h5>
                <p>(555) 123-ROAD</p>
            </div>
            <div class="col-md-4">
                <i class="bi bi-envelope display-6 text-primary mb-2"></i>
                <h5>Email Us</h5>
                <p>info@roadsfix.com</p>
            </div>
            <div class="col-md-4">
                <i class="bi bi-geo-alt display-6 text-primary mb-2"></i>
                <h5>Visit Us</h5>
                <p>123 Road Way<br>City, State 12345</p>
            </div>
        </div>
    </section>
    </div> 
</div>
    
        
  


